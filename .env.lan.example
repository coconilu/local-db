# Copy this file to .env.lan only when LAN access is intentional.
# Start with: docker compose --env-file .env --env-file .env.lan up -d --build
# Replace the IP below with this host's actual LAN IP before use.

LOCAL_DB_BIND_ADDRESS=0.0.0.0
REQUIRE_DASHBOARD_AUTH=true
DASHBOARD_ACCESS_TOKEN=replace-with-a-long-random-lan-access-token
DASHBOARD_ALLOWED_ORIGINS=http://192.168.1.100:15173
