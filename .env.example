# Generate two independent, high-entropy passwords before first startup.
# Do not reuse a password from another service and never commit this file as .env.
LOCAL_DB_ADMIN_PASSWORD=replace-with-a-random-admin-password
LOCAL_DB_DASHBOARD_PASSWORD=replace-with-a-random-dashboard-password

# Safe default: the database and dashboard can only be reached from this computer.
LOCAL_DB_BIND_ADDRESS=127.0.0.1
LOCAL_DB_POSTGRES_PORT=5432
LOCAL_DB_DASHBOARD_PORT=15173

# Leave authentication disabled only for the localhost-only default mode.
REQUIRE_DASHBOARD_AUTH=false
DASHBOARD_ACCESS_TOKEN=
DASHBOARD_ALLOWED_ORIGINS=http://127.0.0.1:15173,http://localhost:15173

# Optional: required to enable the dashboard's "手动添加仓库" AI analysis.
OPENAI_API_KEY=
OPENAI_MODEL=
